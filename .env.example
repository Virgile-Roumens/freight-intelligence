# Copy to .env and fill in. .env is gitignored — never commit real keys.

# FRED — https://fred.stlouisfed.org/docs/api/api_key.html (free)
FRED_API_KEY=

# aisstream.io — https://aisstream.io (free tier; required for live AIS map & morning briefing)
AIS_API_KEY=

# Optional — newsapi.org
NEWS_API_KEY=

# ── Morning Briefing email bot (only needed for local testing of scripts/morning_briefing.py)
# In production these are configured as GitHub Actions secrets, not in .env.
GMAIL_USER=
GMAIL_APP_PASSWORD=
